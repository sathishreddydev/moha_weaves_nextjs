# 🔐 Authentication & Environment Configuration

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-jwt-key-here-change-in-production

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/mohaweavs_db

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRY=30d

# Production URLs (uncomment for production)
# NEXTAUTH_URL=https://yourdomain.com
# NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Admin API Configuration
ADMIN_API_URL=http://localhost:8000/api
ADMIN_API_KEY=your-admin-api-key-here

# Environment
NODE_ENV=development

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Razorpay Payment Configuration
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id

# Security Headers (production)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional Services
# REDIS_URL=redis://localhost:6379
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SENTRY_DSN=https://your-sentry-dsn-here
