environments/.env.prod
environments/.env.vps
environments/.env.development
environments/.env.stage
environments/.env.beta

# SSL certificates
nginx/ssl/


# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/

